{
  "log": {
    "level": "info",
    "timestamp": true
  },

  "inbounds": [
    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "::",
      "listen_port": 60080,
      "network": "tcp,udp",
      "sniff": true,
      "sniff_override_destination": true
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "0.0.0.0",
      "listen_port": 1080
    }
  ],

  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": [
        "airport-vmess",
        "airport-trojan",
        "direct"
      ],
      "default": "airport-vmess"
    },
    {
      "type": "vmess",
      "tag": "airport-vmess",
      "server": "example.com",
      "server_port": 443,
      "uuid": "11111111-2222-3333-4444-555555555555",
      "security": "auto",
      "tls": {
        "enabled": true,
        "server_name": "example.com"
      }
    },
    {
      "type": "trojan",
      "tag": "airport-trojan",
      "server": "example2.com",
      "server_port": 443,
      "password": "password123",
      "tls": {
        "enabled": true,
        "server_name": "example2.com"
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    },
    {
      "type": "dns",
      "tag": "dns-out"
    }
  ],

  "route": {
    "rules": [
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": ["geoip-cn"],
        "outbound": "direct"
      },
      {
        "rule_set": ["geosite-cn"],
        "outbound": "direct"
      },
      {
        "domain_suffix": ["google.com", "youtube.com", "twitter.com", "x.com", "telegram.org"],
        "outbound": "proxy"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://github.com/SagerNet/sing-geoip/releases/latest/download/geoip.db"
      },
      {
        "type": "remote",
        "tag": "geosite-cn",
        "format": "binary",
        "url": "https://github.com/SagerNet/sing-geosite/releases/latest/download/geosite.db"
      }
    ],
    "auto_detect_interface": true,
    "final": "proxy"
  },

  "dns": {
    "servers": [
      {
        "type": "udp",
        "tag": "dns_local",
        "server": "223.5.5.5",
        "strategy": "prefer_ipv4"
      },
      {
        "type": "https",
        "tag": "dns_remote",
        "server": "8.8.8.8",
        "detour": "proxy",
        "strategy": "prefer_ipv4"
      }
    ],
    "rules": [
      {
        "rule_set": ["geosite-cn"],
        "server": "dns_local"
      },
      {
        "outbound": ["proxy"],
        "server": "dns_remote"
      }
    ],
    "strategy": "prefer_ipv4",
    "independent_cache": true,
    "listen": "0.0.0.0:5353"
  }
}
