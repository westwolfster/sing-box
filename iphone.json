{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "proxy_dns",
        "address": "https://8.8.8.8/dns-query",
        "detour": "Default",
        "address_resolver": "cn_dns"
      },
      {
        "tag": "cn_dns",
        "address": "223.5.5.5",
        "detour": "direct"
      },
      {
        "tag": "fake_dns",
        "address": "fakeip"
      }
    ],
    "rules": [
        {
            "domain_suffix": ["jsdeliver.net","github.com","githubusercontent.com"],
            "server": "cn_dns"
        },
        {
          "type": "logical",
          "mode": "or",
          "rules": [
            {"domain_suffix": [".cn", "ileidian.com", "ireader.com", "zhangyue.com"]},
            {"domain_keyword": ["stun", "zhangyue", "ireader", "turn", "wpad"]},
            {"rule_set": "geosite-cn"}
           ],
          "server": "cn_dns"
        },
        {
          "query_type": ["A", "AAAA"],
          "server": "fake_dns",
          "rewrite_ttl": 1
        }
    ],
    "independent_cache": true,
    "final": "proxy_dns",
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15",
      "inet6_range": "3ffe::/16"
    }
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "inet4_address": ["172.19.0.1/30"],
      "inet6_address": ["2001:0470:f9da:fdfa::1/64"],
      "mtu": 1400,
      "auto_route": true,
      "strict_route": true,
      "endpoint_independent_nat": true,
      "stack": "system",
      "sniff": true,
      "sniff_override_destination": true
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 2334,
      "sniff": true,
      "sniff_override_destination": true
    }
  ],
  "outbounds": [
    {
      "tag": "Default",
      "type": "selector",
      "outbounds": ["Auto", "direct"]
    },
    {
      "tag": "Auto",
      "type": "urltest",
      "outbounds": [],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "5m",
      "tolerance": 150
    },
    {"tag": "direct", "type": "direct"},
    {"tag": "block", "type": "block"}
  ],
  "route": {
    "final": "Default",
    "auto_detect_interface": true,
    "rules": [
      {"ip_is_private": true, "outbound": "direct"},
      {"domain_keyword": ["wpad"], "outbound": "direct"},
      {"domain_suffix": ["mshome.net","jsdelivr.net","github.com","githubusercontent.com"], "outbound": "direct"},
      {"domain_suffix": ["events.data.microsoft.com", "self.events.data.microsoft.com"], "outbound": "direct"},
      {"domain_suffix": ["ileidian.com", "zhangyue.com", "ireader.com"], "outbound": "direct"},
      {"rule_set": ["geosite-cn", "geoip-cn"], "outbound": "direct"},
      {"ip_cidr": ["198.18.0.0/15", "3ffe::/16"], "outbound": "Default"}
    ],
    "rule_set": [
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/cn.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/cn.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "store_fakeip": true
    }
  }
}