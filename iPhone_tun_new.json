{
  "log": {
    "disabled": false,
    "level": "info",
    "output": "sing-box.log",
    "timestamp": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    },
    "clash_api": {
      "default_mode": "Rule",
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip",
      "external_ui_download_detour": "Proxy"
    }
  },
  "dns": {
    "servers": [
      {"tag": "remote", "address": "fakeip"},
      {"tag": "ali", "address": "https://223.5.5.5/dns-query", "detour": "direct"},
      {"tag": "google", "address": "https://8.8.8.8/dns-query", "detour": "Proxy"},
      {"tag": "block", "address": "rcode://success"}
    ],
    "rules": [
      {"clash_mode": "Direct", "server": "ali"},
      {"clash_mode": "Global", "server": "google"},
      {"domain_suffix":["argotunnel.com","cloudflare.com","cloudflare.net"],"server":"ali"},
      {"rule_set": ["cn-domain", "alibaba", "category-games@cn"], "server": "ali"},
      {"rule_set": ["category-ads-all"], "server": "block", "disable_cache": true},
      {"query_type": ["A", "AAAA"], "server": "remote"},
      {"rule_set":"gfw","server":"google"}
    ],
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15",
      "inet6_range": "fc00::/18"
    },
    "independent_cache": true,
    "strategy": "prefer_ipv4",
    "final": "google"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": ["172.18.0.1/30", "fdfe:dcba:9876::1/126"],
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 7080
        }
      },
      "stack": "system",
      "mtu": 1400,
      "route_exclude_address": ["10.0.0.0/8","100.64.0.0/10","169.254.0.0/16","172.16.0.0/12","192.0.0.0/24","192.168.0.0/16"],
      "route_exclude_address_set": ["cn-ip"],
      "auto_route": true,
      "strict_route": true,
      "sniff": true
    },
    {
      "type": "mixed",
      "tag": "mixed",
      "listen": "::",
      "listen_port": 7080,
      "set_system_proxy": false
    }
  ],
  "outbounds": [
    {"tag": "direct", "type": "direct"},
    {"tag": "Proxy", "type": "selector", "outbounds": ["Auto", "direct"]},
    {
      "tag": "Auto",
      "type": "urltest",
      "outbounds": [],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "3m",
      "tolerance": 75
    }
  ],
  "route": {
    "rule_set": [
      {
        "tag": "category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/CHIZI-0618/v2ray-rules-dat/release/singbox_rule_set/geosite-category-ads-all.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "tag": "alibaba",
        "type": "remote",
        "format": "binary",
        "url": "http://ghfast.top/https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-alibaba.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "tag": "gfw",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/gfw.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "tag": "category-games@cn",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/category-games-!cn@cn.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "tag": "cn-domain",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/cn.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "tag": "cn-ip",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/cn.srs",
        "download_detour": "Proxy",
        "update_interval": "10d"
      }
    ],
    "rules": [
      {"ip_cidr":["223.5.5.5/32","119.29.29.29/32","114.114.114.114/32"],"action":"route","outbound":"direct"},
      {"inbound":"tun-in","port":53,"action":"hijack-dns"},
      {"ip_cidr":["198.18.0.0/15"],"action":"route","outbound":"Proxy"},
      {"action":"sniff"},
      {"ip_is_private":true,"outbound":"direct"},
      {"rule_set":"gfw","outbound":"Proxy"},
      {"port":53,"action":"route","outbound":"direct"},
      {"domain_suffix":[".qpon"],"action":"route","outbound":"direct"},      
      {"protocol":"quic","action":"reject"},      
      {"clash_mode": "Direct", "action": "route", "outbound": "direct"},
      {"clash_mode": "Global", "action": "route", "outbound": "Proxy"},
      {"rule_set": ["alibaba", "category-games@cn"], "action": "route", "outbound": "direct"},
      {"type": "logical", "mode": "and", "rules": [{"clash_mode": "AllowAds", "invert": true}, {"rule_set": ["category-ads-all"]}], "action": "reject"},
      {"rule_set": ["cn-domain"], "action": "route", "outbound": "direct"},
      {"rule_set": "cn-ip", "action": "route", "outbound": "direct"},
      {"action":"resolve"}
    ],
    "final": "Proxy"
  }
}
